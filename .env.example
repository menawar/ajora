# ---- Contracts (Foundry) ----
# RPC endpoints
CELO_RPC_URL=https://forno.celo.org
ALFAJORES_RPC_URL=https://alfajores-forno.celo-testnet.org

# Deploy key (NEVER commit a real key). Use a throwaway for testnet.
PRIVATE_KEY=

# Deploy params
# Mainnet cUSD:   0x765DE816845861e75A25fCA122bb6898B8B1282a
# Alfajores cUSD: 0x874069Fa1Eb16D44d622F2e0Ca25eeA172369bC1
STABLECOIN=0x874069Fa1Eb16D44d622F2e0Ca25eeA172369bC1
MIN_CONTRIBUTION=100000000000000000
# Roles (both default to the deployer when unset)
VERIFIER=
KEEPER=

# Celoscan API key for contract verification (optional)
CELOSCAN_API_KEY=

# ---- App (frontend) ----
# Defaults in code point at the live Celo mainnet core; override for testnet.
NEXT_PUBLIC_CHAIN_ID=42220
NEXT_PUBLIC_POTVAULT_ADDRESS=
NEXT_PUBLIC_STREAKSBT_ADDRESS=
NEXT_PUBLIC_SPRAYFAUCET_ADDRESS=
NEXT_PUBLIC_DRAWMANAGER_ADDRESS=
