# Celo mainnet RPC. Defaults to the public forno endpoint (ponder.config.ts);
# set a dedicated provider (Alchemy/QuickNode) for faster backfill in production.
PONDER_RPC_URL_42220=

# (Optional) Postgres connection string. Without it Ponder uses embedded PGlite —
# fine for dev; use Postgres for production deploys.
DATABASE_URL=
