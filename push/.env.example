# Web Push VAPID keys — generate once with `npm run vapid`, keep the private key secret.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@ajora.example

# Indexer read API (leaderboards service) — source of draw digests + at-risk streaks.
INDEXER_URL=http://localhost:42069

# Bearer token protecting the manual /tick/* endpoints (keeper cron uses this).
TICK_TOKEN=

# SQLite file for subscriptions + delivery log. ":memory:" for tests.
DB_PATH=./push.db

PORT=42070
